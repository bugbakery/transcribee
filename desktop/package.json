    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "autoprefixer": "^10.4.16",
    "clsx": "^1.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "slate": "^0.94.1",
