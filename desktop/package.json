    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.33.2",
    "npm-run-all": "^4.1.5",
